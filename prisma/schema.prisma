generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model OtpVerification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  phone     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_verifications")
}

model User {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  email      String   @unique
  phone      String?  @unique
  password   String
  role       String   @default("user")
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("users")
}

model Product {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String   @unique
  name      String
  category  String
  sku       String   @unique
  stock     Int      @default(0)
  price     Int      @default(0)
  status    String   @default("In Stock")
  sold      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model Store {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId          String   @unique
  userId           String   @db.ObjectId
  storeName        String
  storeType        String
  storePhone       String
  storeEmail       String?
  storeAddress     String
  storeCity        String
  storeDistrict    String?          
  storeVillage     String?          
  storeProvince    String
  storePostalCode  String?
  storeProvinsiKd  String?          
  storeKotaKd      String?          
  storeKecamatanKd String?          
  storeKelurahanKd String?        
  storeLat         String?        
  storeLng         String?          
  status           String   @default("active")
  owner            Owner?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("stores")
}

type Owner {
  nik         String
  fullName    String
  birthDate   String
  address     String
  gender      String
  ktpImageUrl String?
  inputMethod String  @default("manual")
}

// ── Wilayah ──────────────────────────────────────────────

model MsProvinsi {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  kdProvinsi   String @unique @map("Kd_Provinsi")
  namaProvinsi String @map("NamaProvinsi")

  @@map("ms_provinsi")
}

model MsKota {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  kdKota       String  @unique @map("Kd_Kota")
  namaKota     String  @map("NamaKota")
  kdProvinsi   String  @map("Kd_Provinsi")

  @@map("ms_kota")
}

model MsKecamatan {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  kdKecamatan   String @unique @map("Kd_Kecamatan")
  namaKecamatan String @map("NamaKecamatan")
  kdKota        String @map("Kd_Kota")

  @@map("ms_kecamatan")
}

model MsKelurahan {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  kdKelurahan   String  @unique @map("Kd_Kelurahan")
  namaKelurahan String  @map("NamaKelurahan")
  kdKecamatan   String  @map("Kd_Kecamatan")
  kodePos       String? @map("KodePos")

  @@map("ms_kelurahan")
}
