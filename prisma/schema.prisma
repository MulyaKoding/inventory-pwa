generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model OtpVerification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  phone     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_verifications")
}

model User {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  email      String   @unique
  phone      String?  @unique
  password   String
  role       String   @default("user")
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("users")
}

model Product {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String   @unique
  name      String
  category  String
  sku       String   @unique
  stock     Int      @default(0)
  price     Int      @default(0)
  status    String   @default("In Stock")
  sold      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model Store {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId          String   @unique
  userId           String   @db.ObjectId
  storeName        String
  storeType        String
  storePhone       String
  storeEmail       String?
  storeAddress     String
  storeCity        String
  storeDistrict    String?          
  storeVillage     String?          
  storeProvince    String
  storePostalCode  String?
  storeProvinsiKd  String?          
  storeKotaKd      String?          
  storeKecamatanKd String?          
  storeKelurahanKd String?        
  storeLat         String?        
  storeLng         String?       
  storeImageUrl    String?      
  status           String   @default("active")
  owner            Owner?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("stores")
}

type Owner {
  nik         String
  fullName    String
  birthDate   String
  address     String
  gender      String
  ktpImageUrl String?
  signatureUrl String? 
  inputMethod String  @default("manual")
}

// ── Wilayah ──────────────────────────────────────────────

model MsProvinsi {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  kdProvinsi   String @unique @map("Kd_Provinsi")
  namaProvinsi String @map("NamaProvinsi")

  @@map("ms_provinsi")
}

model MsKota {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  kdKota       String  @unique @map("Kd_Kota")
  namaKota     String  @map("NamaKota")
  kdProvinsi   String  @map("Kd_Provinsi")

  @@map("ms_kota")
}

model MsKecamatan {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  kdKecamatan   String @unique @map("Kd_Kecamatan")
  namaKecamatan String @map("NamaKecamatan")
  kdKota        String @map("Kd_Kota")

  @@map("ms_kecamatan")
}

model MsKelurahan {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  kdKelurahan   String  @unique @map("Kd_Kelurahan")
  namaKelurahan String  @map("NamaKelurahan")
  kdKecamatan   String  @map("Kd_Kecamatan")
  kodePos       String? @map("KodePos")

  @@map("ms_kelurahan")
}

model Mitra {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  mitraId          String    @unique
  picName          String
  picEmail         String    @unique
  picPhone         String
  picPosition      String
  picKtp           String?
  companyName      String
  companyType      String
  companyNpwp      String?
  companyAddress   String
  companyCity      String
  companyProvince  String?
  companyPostal    String?
  companyWebsite   String?
  employeeCount    String?
  plan             String    @default("growth")
  planPrice        Int       @default(0)
  paymentId        String?
  status           String    @default("pending")
  activatedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("mitras")
}

model MitraPayment {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  invoiceNumber String    @unique
  mitraId       String?
  picName       String
  picEmail      String
  companyName   String
  plan          String
  amount        Int
  status        String    @default("pending")
  dokuRequestId String?
  dokuSessionId String?
  rawResponse   String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("mitra_payments")
}

model MsSatuanBarang {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  kdSatuanBarang  String    @unique @map("Kd_SatuanBarang")   // ← ubah
  deskripsiSatuan String    @map("DeskripsiSatuan")
  createdAt       DateTime  @default(now()) @map("Created_at")
  modifiedAt      DateTime  @updatedAt @map("Modified_at")
  deleteAt        DateTime? @map("Delete_at")

  @@map("ms_satuan_barang")
}

// ── Master Supplier ──────────────────────────────────────
model MsSupplierBarang {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  supplierCode String   @unique @map("Supplier_Code")   
  supplierName String   @map("Supplier_Name")
  phone        String?  @map("Phone")
  email        String?  @map("Email")
  address      String?  @map("Address")
  city         String?  @map("City")
  province     String?  @map("Province")
  picName      String?  @map("Pic_Name")               
  status       String   @default("active") @map("Status")

  // Kepemilikan
  storeId      String   @map("Store_Id")               
  userId       String   @map("User_Id") @db.ObjectId   

  createdAt    DateTime @default(now()) @map("Created_at")
  modifiedAt   DateTime @updatedAt @map("Modified_at")
  deleteAt     DateTime? @map("Delete_at")

  // Relasi ke barang
  barangs      MsBarang[]

  @@index([storeId])
  @@index([userId])
  @@map("ms_supplier_barang")
}

// ── Master Pabrik ────────────────────────────────────────
model MsPabrikBarang {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  pabrikCode  String   @unique @map("Pabrik_Code")     
  pabrikName  String   @map("Pabrik_Name")
  phone       String?  @map("Phone")
  email       String?  @map("Email")
  address     String?  @map("Address")
  city        String?  @map("City")
  province    String?  @map("Province")
  country     String?  @map("Country") @default("Indonesia")
  status      String   @default("active") @map("Status")

  // Kepemilikan
  storeId     String   @map("Store_Id")
  userId      String   @map("User_Id") @db.ObjectId

  createdAt   DateTime  @default(now()) @map("Created_at")
  modifiedAt  DateTime  @updatedAt @map("Modified_at")
  deleteAt    DateTime? @map("Delete_at")

  // Relasi ke barang
  barangs     MsBarang[]

  @@index([storeId])
  @@index([userId])
  @@map("ms_pabrik_barang")
}

// ── Master Merek ─────────────────────────────────────────
model MsMerekBarang {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  merekCode  String   @unique @map("Merek_Code")
  merekName  String   @map("Merek_Name")
  pabrikCode String?  @map("Pabrik_Code")   // ← tambah ini
  status     String   @default("active") @map("Status")

  storeId    String   @map("Store_Id")
  userId     String   @map("User_Id") @db.ObjectId

  createdAt  DateTime  @default(now()) @map("Created_at")
  modifiedAt DateTime  @updatedAt @map("Modified_at")
  deleteAt   DateTime? @map("Delete_at")

  barangs    MsBarang[]

  @@index([storeId])
  @@index([pabrikCode])   // ← tambah index
  @@index([userId])
  @@map("ms_merek_barang")
}

// ── Master Barang ─────────────────────────────────────────
model MsBarang {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  barangCode     String   @unique @map("Barang_Code")
  barangName     String   @map("Barang_Name")
  barangCategory String?  @map("Barang_Category")
  supplierCode   String?  @map("Supplier_Code")
  pabrikCode     String?  @map("Pabrik_Code")
  merekCode      String?  @map("Merek_Code")
  kdSatuanBarang String?  @map("Kd_SatuanBarang")
  storeId        String   @map("Store_Id")
  userId         String   @map("User_Id") @db.ObjectId
  stock          Int      @default(0) @map("Stock")
  price          Int      @default(0) @map("Price")
  hargaBeli      Int      @default(0) @map("Harga_Beli")  // ← tambah ini
  barcode        String?  @map("Barcode")                  // ← ini juga belum ada!
  status         String   @default("active") @map("Status")
  createdAt      DateTime @default(now()) @map("Created_at")
  modifiedAt     DateTime @updatedAt @map("Modified_at")
  deleteAt       DateTime? @map("Delete_at")

  supplier  MsSupplierBarang? @relation(fields: [supplierCode], references: [supplierCode])
  pabrik    MsPabrikBarang?   @relation(fields: [pabrikCode], references: [pabrikCode])
  merek     MsMerekBarang?    @relation(fields: [merekCode], references: [merekCode])

  @@index([storeId])
  @@index([supplierCode])
  @@index([pabrikCode])
  @@index([merekCode])
  @@map("ms_barang")
}
